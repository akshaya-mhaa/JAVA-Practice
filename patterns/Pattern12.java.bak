import java.util.Scanner;
class Pattern12
{
	public static void main(String[] args) 
	{
		System.out.println("Enter a number:");
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt();
		for(int i=1;i<=n;i++){
			for(int j=1;j<=n;j++){
				if(i>=j+1)
					System.out.print(	i+" ");
				else
					System.out.print("  ");
			}
			System.out.println();
		}
	}
}
