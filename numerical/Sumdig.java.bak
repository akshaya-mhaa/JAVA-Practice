import java.util.Scanner;
class Sumdig 
{
	static Scanner sc=nw Scanner(System.in);
	public static void main(String[] args) 
	{
		System.out.println("Enter a number:");
		int n=sc.nextInt();
		int sum=0;
		if(n>0 && n<9999){
			while (n!=0)
			{
				int l=n%10;
				sum+=l;
				n/=10;
			}
			System.out.println("Sum is"+sum);
		}
		else
			System.out.println("Enter valid number");
	}
}
