import java.util.Scanner;
class sum 
{
	static Scanner sc=new Scanner(System.in);
	public static void main(String[] args) 
	{
		System.out.println("enter a number:");
		int num=sc.nextInt();
		
		int sum=0;
		while(num!=0)
		{
			int l=num%10;
			sum=l+sum;
		}
		num=num/10;
		System.out.println(sum);
	}
}
