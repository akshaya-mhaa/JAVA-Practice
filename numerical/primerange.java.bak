import java.util.Scanner;
class primerange 
{
	static Scanner sc= new Scanner(System.in);
	public static void main(String[] args) 
	{
		System.out.println("Enter a number:");
		int n=sc.nextInt();
		
		for(int i=1;i<=n;i++)
		{
			int count=0;
			for(int j=2;j<n;j++)
			{
				if(i%j==0)
					count++;
				if (count==0)
				{
					System.out.println(j);
				}
			}
		}
				
	}
}
