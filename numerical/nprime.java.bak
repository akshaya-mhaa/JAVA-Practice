import java.util.Scanner;
class nprime 
{
	static Scanner sc=new Scanner(System.in);
	public static void main(String[] args) 
	{
		System.out.println("Enter a number:");
		int n=sc.nextInt();
		int c=0;
		
		for(int i=0;i<=c;i++)
		{
			int d=0;
			for(int j=2;j<=i;j++)
			{
				if(i%j==0)
					d++;
			}
			if(d==1)
			{
				System.out.println(i);
				c++;
			}
		}
	}
}
