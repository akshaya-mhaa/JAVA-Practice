import java.util.Scanner;
class array
{
	static Scanner sc=new Scanner(System.in);
	public static void main(String[] args)
	{
		System.out.println("enter the number of values:");
		int n=sc.nextInt();
		int[] arr=new int[n];
		System.out.println("enter the values:");
		for(int i=0;i<n;i++)
		{
			arr[i]=sc.nextInt();
		}
	}
}