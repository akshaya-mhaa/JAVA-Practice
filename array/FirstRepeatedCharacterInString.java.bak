class FirstRepeatedCharacterInString
{
	public static void main(String[] args) 
	{
		String str="Anand";
		str=str.toLowerCase();
		boolean flag=false;
		for(int i=0;i<str.length();i++){
			for(int j=i+1;j<str.length();j++){
				if(str.(str.charAt(j)){
					System.out.println("First repeated number is "+ str.charAt(i));
					flag=true;
					break;
				}
				if(flag==true)
					break;
			}
		}
	}
}
