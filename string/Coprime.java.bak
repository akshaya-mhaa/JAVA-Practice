import java.util.Scanner;
class CoPrime 
{
	public static void main(String[] args) 
	{
		Scanner sc=new Scanner(System.in);
		int a=sc.nextInt();
		int b=sc.nextInt();
		int cp=0;
		int max=0;
		if(a>b)
			max=a;
		else
			max=b;
		for(int i=1;i<=max;i++){
			if(a%i==0&&b%i==0)
				cp=i;
		}
		if(cp==1)
			System.out.println(a+","+b+" are co-prime");
	}
}
