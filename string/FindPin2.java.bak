class FindPin2 
{
	public static void main(String[] args) 
	{
		int n1=3521;
		int n2=2452;
		int n3=1352;
		int n4=38;
		int sum=(lar(n1)*lar(n2)*lar(n3))+n4;
		System.out.println(sum);
	}
	
	public static int lar(int a){
		int lar=0;
		while(a!=0){
			int l=a%10;
			if(l>lar)
				lar=l;
			
			a/=10;
		}
		return lar;
	}
}
